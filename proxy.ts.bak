import { NextResponse, type NextRequest } from 'next/server'

export async function proxy(request: NextRequest) {
  const sessionCookie = request.cookies.get('employee_session');
  let session = null;

  if (sessionCookie) {
    try {
      session = JSON.parse(sessionCookie.value);
    } catch (e) {
      console.error("Invalid session cookie");
    }
  }

  // 1. Protect /employee routes
  if (request.nextUrl.pathname.startsWith('/employee')) {
    // Let them access login and create-account without a session
    if (request.nextUrl.pathname.startsWith('/employee/login') || 
        request.nextUrl.pathname.startsWith('/employee/create-account')) {
      // If already logged in, redirect away from login
      if (session && request.nextUrl.pathname === '/employee/login') {
        return NextResponse.redirect(new URL('/employee', request.url));
      }
      return NextResponse.next();
    }

    // Require session for all other /employee routes
    if (!session) {
      return NextResponse.redirect(new URL('/employee/login', request.url));
    }
  }

  // 2. Protect /admin routes from non-admins
  if (request.nextUrl.pathname.startsWith('/admin')) {
    if (session && session.role !== 'Admin') {
      return NextResponse.redirect(new URL('/employee', request.url));
    }
  }

  return NextResponse.next();
}

export const config = {
  matcher: [
    '/((?!_next/static|_next/image|favicon.ico|.*\\.(?:svg|png|jpg|jpeg|gif|webp)$).*)',
  ],
}
